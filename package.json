{
  "name": "sports-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for The Odds API and SportMonks Football API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sports-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/server-http.js",
    "dev": "tsc && node dist/index.js",
    "dev:http": "tsc && node dist/server-http.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
